# ============ MORPHO PROTOCOL ============
MORPHO_BLUE="0xBBBBBbbBBb9cC5e90e3b3Af64bdAF62C37EEFFCb"
BASE_USDC="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
