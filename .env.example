# ============================================================
# SMART CONTRACT DEPLOYMENT ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# NEVER commit .env or .env.production to version control.
#
# GitHub Actions equivalent: add each variable as a repository
# Secret at: Settings → Secrets and variables → Actions → New secret
# ============================================================

# ============ DEPLOYER WALLET (GitHub Secret: DEPLOYER_PRIVATE_KEY) ============
# The private key of the wallet used to deploy contracts.
# KEEP THIS SECRET — never share or commit this value.
# This wallet must hold ETH (Story Protocol) and ETH (Base L2) for gas fees.
DEPLOYER_PRIVATE_KEY="YOUR_DEPLOYER_PRIVATE_KEY_HERE"

# ============ BLOCKCHAIN NETWORKS ============
# Optional: override the default public RPC endpoints.
# GitHub Secrets: STORY_RPC_URL, BASE_RPC_URL
#
# If you have an Alchemy account, set ALCHEMY_API_KEY and the workflow will
# automatically use the Alchemy Story Protocol endpoint:
#   https://story-mainnet.g.alchemy.com/v2/<ALCHEMY_API_KEY>
# Obtain your key at: https://dashboard.alchemy.com → Create App → Story Protocol
ALCHEMY_API_KEY="YOUR_ALCHEMY_API_KEY"

# If ALCHEMY_API_KEY is set, STORY_RPC_URL is constructed automatically.
# You may override it explicitly here if you prefer a different provider.
STORY_RPC_URL="https://mainnet.storyrpc.io"
BASE_RPC_URL="https://mainnet.base.org"
MAINNET_RPC_URL="https://cloudflare-eth.com"

# ============ CONTRACT VERIFICATION API KEYS ============
# StoryScan (Story Protocol) — GitHub Secret: STORYSCAN_API_KEY
STORYSCAN_API_KEY="YOUR_STORYSCAN_API_KEY"

# Etherscan / Basescan — GitHub Secret: ETHERSCAN_API_KEY
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"

# ============ MULTI-SIGNATURE WALLETS (Morpho Protocol — 2/2 required) ============
# Public wallet addresses; no secrets needed for these.
STORY_DEPLOYER_ADDRESS="0x597856e93f19877a399f686D2F43b298e2268618"
COINBASE_WALLET_ADDRESS="0xDc2aFCd0a97c1e878FdD64497806E52Cc530f02a"

# ============ COINBASE DEVELOPER PLATFORM (CDP) ============
# CDP API credentials for Coinbase Developer Platform services.
# These are NOT Ethereum private keys — they authenticate REST API calls to
# Coinbase's backend.  Generate/rotate at: https://portal.cdp.coinbase.com/access/api
# GitHub Secrets: COINBASE_API_KEY_NAME, COINBASE_API_KEY_PRIVATE_KEY
COINBASE_API_KEY_NAME="YOUR_CDP_API_KEY_NAME"
COINBASE_API_KEY_PRIVATE_KEY="YOUR_CDP_API_KEY_PRIVATE_KEY"

# ============ THIRDWEB SDK ============
# Thirdweb client credentials for SDK-based wallet and contract interactions.
# GitHub Secrets: THIRDWEB_CLIENT_ID, THIRDWEB_SECRET_KEY
# Generate at: https://thirdweb.com/dashboard/settings/api-keys
THIRDWEB_CLIENT_ID="YOUR_THIRDWEB_CLIENT_ID"
THIRDWEB_SECRET_KEY="YOUR_THIRDWEB_SECRET_KEY"

# ============ PINATA IPFS CONFIGURATION ============
PINATA_API_KEY="YOUR_PINATA_API_KEY"
PINATA_SECRET_API_KEY="YOUR_PINATA_SECRET_API_KEY"
PINATA_JWT="YOUR_PINATA_JWT"
# The gateway subdomain for your dedicated Pinata gateway (e.g., "lavender-neat-urial-76").
# Find it at: https://app.pinata.cloud/gateway
PINATA_GATEWAY_NAME="lavender-neat-urial-76"
# A gateway access token (optional — only for private/restricted gateways).
# Generate/rotate at: https://app.pinata.cloud/gateway → your gateway → Manage Tokens
# KEEP THIS SECRET — never share or commit this value.
PINATA_GATEWAY_TOKEN="YOUR_PINATA_GATEWAY_TOKEN"

# ============ DOCUMENT HASHES (IPFS CIDs) ============
# Primary loan documents (already deployed on-chain via UCC-1 filing)
UCC1_FILING_HASH="bafkreialofdl6qhrgyomohyo6giijf7stzl26r6sbvq6gnwakgqpbqoe4a"
