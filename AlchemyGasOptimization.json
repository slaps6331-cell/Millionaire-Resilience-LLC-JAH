{
  "$schema": "https://docs.alchemy.com/gas-optimization-schema.json",
  "configuration": {
    "name": "Gladiator Holdings Story Protocol Deployment",
    "version": "1.0.0",
    "provider": "Alchemy",
    "optimizationLevel": "maximum"
  },
  "networks": {
    "storyProtocol": {
      "chainId": 1514,
      "chainName": "Story Protocol Mainnet",
      "rpcEndpoint": "https://story-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}",
      "nativeToken": "$IP",
      "gasSettings": {
        "maxFeePerGas": "auto",
        "maxPriorityFeePerGas": "auto",
        "gasLimit": "auto",
        "gasPriceMultiplier": 1.1,
        "retryOnFailure": true,
        "maxRetries": 3,
        "retryDelayMs": 2000
      }
    },
    "baseL2": {
      "chainId": 8453,
      "chainName": "Base Mainnet",
      "rpcEndpoint": "https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}",
      "nativeToken": "ETH",
      "gasSettings": {
        "maxFeePerGas": "auto",
        "maxPriorityFeePerGas": "auto",
        "gasLimit": "auto",
        "gasPriceMultiplier": 1.05,
        "retryOnFailure": true,
        "maxRetries": 3,
        "retryDelayMs": 1000
      }
    }
  },
  "gasOracle": {
    "enabled": true,
    "updateIntervalMs": 10000,
    "strategy": "percentile",
    "percentile": 50,
    "fallbackGwei": {
      "storyProtocol": 1,
      "baseL2": 0.001
    }
  },
  "transactionOptimization": {
    "batchingEnabled": true,
    "maxBatchSize": 10,
    "priorityOrdering": [
      "contractDeployment",
      "ipRegistration",
      "licenseAttachment",
      "attestationCreation",
      "documentRecording"
    ],
    "parallelExecution": true,
    "maxParallelTransactions": 3
  },
  "costEstimates": {
