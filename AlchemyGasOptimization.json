  "deploymentScript": {
    "preDeploymentChecks": [
      "verifyAlchemyAPIKey",
      "checkIPTokenBalance",
      "validateContractBytecode",
      "estimateGasCosts"
    ],
    "deploymentSteps": [
      {
        "step": 1,
        "name": "Deploy GladiatorHoldingsSpvLoan to Story",
        "network": "storyProtocol",
        "estimatedGas": 2000000,
        "priority": "high"
      },
      {
        "step": 2,
        "name": "Deploy GladiatorHoldingsSpvLoan to Base",
        "network": "baseL2",
        "estimatedGas": 2000000,
        "priority": "high"
      },
      {
        "step": 3,
        "name": "Register MR IP Asset",
        "network": "storyProtocol",
        "estimatedGas": 500000,
        "priority": "high"
      },
      {
        "step": 4,
        "name": "Register SLAPS IP Asset",
        "network": "storyProtocol",
        "estimatedGas": 500000,
        "priority": "high"
      },
      {
        "step": 5,
        "name": "Attach PIL Licenses (batch)",
        "network": "storyProtocol",
        "estimatedGas": 900000,
        "priority": "medium"
      },
      {
        "step": 6,
        "name": "Create Attestations (batch)",
        "network": "storyProtocol",
        "estimatedGas": 800000,
        "priority": "medium"
      },
      {
        "step": 7,
        "name": "Record UCC-1 Hash",
        "network": "storyProtocol",
        "estimatedGas": 100000,
        "priority": "medium"
      },
      {
        "step": 8,
        "name": "Configure Royalty Routing",
        "network": "storyProtocol",
        "estimatedGas": 150000,
        "priority": "medium"
      },
      {
        "step": 9,
        "name": "Seal Hermetic Loop",
        "network": "storyProtocol",
        "estimatedGas": 80000,
        "priority": "low"
      }
    ],
    "postDeploymentVerification": [
      "verifyContractDeployment",
      "verifyIPRegistration",
      "verifyLicenseAttachment",
      "verifyAttestations",
      "verifyRoyaltyRouting",
      "verifyHermeticSeal"
    ]
  },
  "environment": {
    "requiredSecrets": [
      "ALCHEMY_API_KEY",
      "PRIVATE_KEY",
      "ETHERSCAN_API_KEY"
    ],
    "optionalSecrets": [
      "CDP_API_KEY_NAME",
      "CDP_PRIVATE_KEY"
    ]
  }
}
