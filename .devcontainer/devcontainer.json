{
  "name": "Gladiator Holdings — Smart Contracts Development",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "JuanBlanco.solidity",
        "esbenp.prettier-vscode",
        "NomicFoundation.hardhat-solidity",
        "ms-vscode.vscode-json"
      ],
      "settings": {
        "[solidity]": {
          "editor.defaultFormatter": "NomicFoundation.hardhat-solidity"
        },
        "solidity.compileUsingRemoteVersion": "v0.8.26+commit.8a97fa7a",
        "solidity.defaultCompiler": "remote",
        "solidity.packageDefaultDependenciesDirectory": "node_modules",
        "solidity.packageDefaultDependenciesContractsDirectory": "",
        "hardhat.projectsDirectories": ["${workspaceFolder}"]
      }
    }
  },
  "postCreateCommand": "npm install --legacy-peer-deps && npm run contracts:compile",
  "remoteUser": "node",
  "forwardPorts": [8545],
  "portsAttributes": {
    "8545": {
      "label": "Hardhat Node",
      "onAutoForward": "notify"
    }
  }
}
